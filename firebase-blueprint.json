{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the ArganOble store",
      "type": "object",
      "properties": {
        "titleAr": { "type": "string", "description": "Arabic title" },
        "titleEn": { "type": "string", "description": "English title" },
        "titleFr": { "type": "string", "description": "French title" },
        "descriptionAr": { "type": "string", "description": "Arabic description" },
        "descriptionEn": { "type": "string", "description": "English description" },
        "descriptionFr": { "type": "string", "description": "French description" },
        "category": { "type": "string", "enum": ["honey", "amlou", "argan"], "description": "Product category" },
        "price": { "type": "number", "description": "Product price in MAD" },
        "shippingCost": { "type": "number", "description": "Shipping cost in MAD" },
        "imageUrl": { "type": "string", "description": "Base64 encoded image or URL" },
        "createdAt": { "type": "number", "description": "Timestamp when product was created" }
      },
      "required": ["titleAr", "titleEn", "titleFr", "descriptionAr", "descriptionEn", "descriptionFr", "category", "price", "shippingCost", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products offered in the store"
    }
  }
}
